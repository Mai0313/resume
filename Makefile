.PHONY: all help clean fmt build run pdf

all: build ## Default target: build the website

help:  ## Show help
	@grep -E '^[.a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | awk 'BEGIN {FS = ":.*?## "}; {printf "\033[36m%-30s\033[0m %s\n", $$1, $$2}'

clean: ## Clean autogenerated files (keeps public/resume.pdf, which is committed to git)
	@rm -rf target dist tmp .cache public/rendercv_output public/photo.jpg
	@find . -type f -name "*.DS_Store" -ls -delete
	@git fetch --prune
	@git gc --prune=now --aggressive

fmt: ## Run code formatters and linters
	yarn run check

pdf: ## Regenerate public/resume.pdf from public/example.yaml. Run this manually after editing the YAML, then commit the updated PDF.
	uv tool install "rendercv[full]"
	uv run rendercv render public/example.yaml --pdf-path resume.pdf -nomd -nohtml -nopng
	@rm -rf public/rendercv_output public/photo.jpg

build: ## Build the website
	yarn build

run: ## Run the project
	yarn start
